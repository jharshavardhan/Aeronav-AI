    "## Cell 5 — Navigation & Physics Engine"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 178,
   "id": "e1f2a3b4",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "✅ Navigation engine ready\n"
     ]
    }
   ],
   "source": [
    "def haversine_nm(a: Airport, b: Airport) -> float:\n",
    "    \"\"\"Great-circle distance in nautical miles using the Haversine formula.\"\"\"\n",
    "    R = 3440.065  # Earth radius in NM\n",
    "    lat1, lat2 = math.radians(a.lat), math.radians(b.lat)\n",
    "    dlat = math.radians(b.lat - a.lat)\n",
    "    dlon = math.radians(b.lon - a.lon)\n",
    "    h = math.sin(dlat/2)**2 + math.cos(lat1)*math.cos(lat2)*math.sin(dlon/2)**2\n",
    "    return R * 2 * math.asin(math.sqrt(h))\n",
    "\n",
    "\n",
    "def generate_eco_waypoints(origin, dest, cruise_fl, n=7):\n",
    "    \"\"\"Interpolate waypoints with sinusoidal jet-stream deviation.\"\"\"\n",
    "    wps = []\n",
    "    for i in range(1, n):\n",
    "        t = i / n\n",
    "        lon = origin.lon + (dest.lon - origin.lon) * t\n",
    "        lat = (origin.lat + (dest.lat - origin.lat) * t\n",
    "               + math.sin(t * math.pi) * 6\n",
    "               + random.uniform(-1.0, 1.0))\n",
    "        wind = round(math.sin(t * math.pi) * 30 + random.uniform(-15, 15))\n",
    "        wps.append(Waypoint(\n",
    "            name=WAYPOINT_NAMES[i % len(WAYPOINT_NAMES)],\n",
    "            lat=round(lat, 2), lon=round(lon, 2),\n",
    "            altitude_fl=cruise_fl, wind_kt=wind\n",
    "        ))\n",
    "    return wps\n",
    "\n",
    "\n",
    "def generate_wind_profile(n=20):\n",
    "    \"\"\"Simulate wind component (kt) at equal intervals along the route.\"\"\"\n",
    "    return [\n",
    "        round(math.sin(i/(n-1)*math.pi)*30 + random.uniform(-15, 15), 1)\n",
    "        for i in range(n)\n",
    "    ]\n",
    "\n",
    "\n",
    "def compute_emission_breakdown(co2_kg):\n",
    "    return {\n",
    "        \"Cruise\":          round(co2_kg * 0.68),\n",
    "        \"Climb/Descent\":   round(co2_kg * 0.18),\n",
    "        \"Ground/Taxi\":     round(co2_kg * 0.07),\n",
    "        \"Contrail Effect\": round(co2_kg * 0.07),\n",
    "    }\n",
    "\n",
    "\n",
    "def compute_route(origin, dest, aircraft, priority=\"eco\", cruise_fl=370):\n",
    "    \"\"\"Core routing engine — returns a complete FlightAnalysis.\"\"\"\n",
    "    dist_nm     = haversine_nm(origin, dest)\n",
    "    flight_hrs  = dist_nm / CRUISE_SPEED_KT\n",
    "    base_fuel   = aircraft.burn_rate_kg_per_hr * flight_hrs\n",
    "    factor      = PRIORITY_FACTOR.get(priority, 0.86)\n",
    "    eco_fuel    = base_fuel * factor\n",
    "    eco_co2     = eco_fuel * CO2_PER_KG_FUEL\n",
    "    base_min    = round(flight_hrs * 60)\n",
    "    time_delta  = round(base_min * (1 - factor))\n",
    "\n",
    "    return FlightAnalysis(\n",
    "        origin=origin, destination=dest, aircraft=aircraft,\n",
    "        priority=priority, cruise_fl=cruise_fl,\n",
    "        distance_nm=round(dist_nm, 1),\n",
    "        eco_route=RouteOption(\n",
    "            \"ECO OPTIMAL\", round(eco_fuel), round(eco_co2),\n",
    "            base_min + time_delta, round(dist_nm), is_eco=True),\n",
    "        standard_route=RouteOption(\n",
    "            \"STANDARD\", round(base_fuel), round(base_fuel * CO2_PER_KG_FUEL),\n",
    "            base_min - 5, round(dist_nm)),\n",
    "        fuel_saved_kg=round(base_fuel - eco_fuel),\n",
    "        co2_saved_kg=round((base_fuel - eco_fuel) * CO2_PER_KG_FUEL),\n",
    "        time_delta_min=time_delta,\n",
    "        wind_profile=generate_wind_profile(),\n",
    "        emission_breakdown=compute_emission_breakdown(round(eco_co2)),\n",
    "        waypoints=generate_eco_waypoints(origin, dest, cruise_fl),\n",
    "    )\n",
    "\n",
    "\n",
    "def all_alternatives(origin, dest, aircraft, cruise_fl):\n",
    "    \"\"\"Return all four strategy RouteOptions for comparison.\"\"\"\n",
    "    dist  = haversine_nm(origin, dest)\n",
    "    hrs   = dist / CRUISE_SPEED_KT\n",
    "    bf    = aircraft.burn_rate_kg_per_hr * hrs\n",
    "    bm    = round(hrs * 60)\n",
    "    return [\n",
    "        RouteOption(\"ECO OPTIMAL\",  round(bf*0.82), round(bf*0.82*CO2_PER_KG_FUEL), bm+18, round(dist), True),\n",
    "        RouteOption(\"BALANCED\",     round(bf*0.89), round(bf*0.89*CO2_PER_KG_FUEL), bm+8,  round(dist)),\n",
    "        RouteOption(\"MIN TIME\",     round(bf*0.96), round(bf*0.96*CO2_PER_KG_FUEL), bm,    round(dist)),\n",
    "        RouteOption(\"STANDARD\",     round(bf),      round(bf*CO2_PER_KG_FUEL),       bm-5,  round(dist)),\n",
    "    ]\n",
    "\n",
    "print(\"✅ Navigation engine ready\")"
   ]
