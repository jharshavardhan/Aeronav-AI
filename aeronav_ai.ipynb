   "source": [
    "# ── Read from widgets (or fall back to defaults) ───────────────────────────\n",
    "ORIGIN_CODE   = w_origin.value   if 'w_origin'   in dir() else \"KJFK\"\n",
    "DEST_CODE     = w_dest.value     if 'w_dest'     in dir() else \"EGLL\"\n",
    "AIRCRAFT_CODE = w_aircraft.value if 'w_aircraft' in dir() else \"B777\"\n",
    "PRIORITY      = w_priority.value if 'w_priority' in dir() else \"eco\"\n",
    "CRUISE_FL     = w_cruise.value   if 'w_cruise'   in dir() else 370\n",
    "\n",
    "origin   = AIRPORTS[ORIGIN_CODE]\n",
    "dest     = AIRPORTS[DEST_CODE]\n",
    "aircraft = AIRCRAFT[AIRCRAFT_CODE]\n",
    "\n",
    "fig_info = go.Figure()\n",
    "\n",
    "fig_info.add_trace(go.Table(\n",
