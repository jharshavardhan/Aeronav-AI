   "source": [
    "print(\"⟳ Computing eco route...\", end=\"\", flush=True)\n",
    "analysis = compute_route(origin, dest, aircraft, PRIORITY, CRUISE_FL)\n",
    "print(\" done\")\n",
    "\n",
    "print(\"⟳ Consulting Gemini AI...\", end=\"\", flush=True)\n",
    "analysis.ai_insight = fetch_ai_insight(analysis)\n",
    "print(\" done\")\n",
    "\n",
    "# ── Summary table ────────────────────────────────────────────────────────────\n",
    "pct = round((1 - PRIORITY_FACTOR[PRIORITY]) * 100)\n",
    "fmt = lambda m: f\"{m//60}h{str(m%60).zfill(2)}m\"\n",
    "\n",
    "\n",
    "fig_table = go.Figure(data=[go.Table(\n",
    "    header=dict(\n",
    "        values=[\"<b>Metric</b>\", \"<b>Value</b>\"],\n",
    "        fill_color=\"#050a12\",\n",
    "        font=dict(color=\"#00d4ff\", size=14),\n",
    "        align=\"left\"\n",
    "    ),\n",
    "    cells=dict(\n",
    "        values=[\n",
    "            [\n",
    "                \"Distance\",\n",
    "                \"Fuel Saved\",\n",
    "                \"CO₂ Avoided\",\n",
    "                \"Time Delta\",\n",
    "                \"Eco Flight Time\",\n",
    "                \"Eco Fuel Total\",\n",
    "                \"Eco CO₂ Total\"\n",
    "            ],\n",
    "            [\n",
    "                f\"{analysis.distance_nm:,.1f} NM\",\n",
    "                f\"{analysis.fuel_saved_kg:,} kg (-{pct}%)\",\n",
    "                f\"{analysis.co2_saved_kg:,} kg (-{pct}%)\",\n",
    "                f\"{analysis.time_delta_min:+} min\",\n",
    "                fmt(analysis.eco_route.flight_time_min),\n",
    "                f\"{analysis.eco_route.total_fuel_kg:,} kg\",\n",
    "                f\"{analysis.eco_route.total_co2_kg:,} kg\"\n",
    "            ]\n",
    "        ],\n",
    "        fill_color=\"#080f1e\",\n",
    "        font=dict(color=\"#c8dff0\", size=13),\n",
    "        align=\"left\",\n",
    "        height=32\n",
    "    )\n",
    ")])\n",
    "\n",
    "fig_table.update_layout(\n",
