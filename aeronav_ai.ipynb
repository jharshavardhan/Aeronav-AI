       "<Figure size 1600x1000 with 4 Axes>"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    },
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "✅ Dashboard saved → eco_dashboard.png\n"
     ]
    }
   ],
   "source": [
    "alts = all_alternatives(origin, dest, aircraft, CRUISE_FL)\n",
    "\n",
    "fig = plt.figure(figsize=(16, 10), facecolor=\"#050a12\")\n",
    "gs  = GridSpec(2, 3, figure=fig, hspace=0.45, wspace=0.35)\n",
    "\n",
    "DARK  = \"#050a12\"\n",
    "PANEL = \"#080f1e\"\n",
    "CYAN  = \"#00d4ff\"\n",
    "GREEN = \"#00ff9d\"\n",
    "AMBER = \"#ffcc00\"\n",
    "ORANGE= \"#ff6b35\"\n",
    "DIM   = \"#4a6a8a\"\n",
    "\n",
    "def style_ax(ax, title):\n",
    "    ax.set_facecolor(PANEL)\n",
    "    ax.spines[:].set_edgecolor(\"#0d2545\")\n",
    "    ax.tick_params(colors=DIM, labelsize=8)\n",
    "    ax.set_title(title, color=CYAN, fontsize=10, fontweight=\"bold\", pad=8)\n",
    "\n",
    "# ── 1. Route comparison — fuel ────────────────────────────────────\n",
    "ax1 = fig.add_subplot(gs[0, 0])\n",
    "style_ax(ax1, \"Fuel Burn by Strategy (t)\")\n",
    "labels = [r.label for r in alts]\n",
    "fuels  = [r.total_fuel_kg/1000 for r in alts]\n",
    "colors = [GREEN if r.is_eco else CYAN for r in alts]\n",
    "bars = ax1.barh(labels, fuels, color=colors, alpha=0.85, height=0.55, edgecolor=\"#0d2545\")\n",
    "for bar, v in zip(bars, fuels):\n",
    "    ax1.text(v + 0.3, bar.get_y() + bar.get_height()/2,\n",
    "             f\"{v:.1f}t\", va=\"center\", color=\"#c8dff0\", fontsize=8)\n",
    "ax1.set_xlabel(\"Fuel (tonnes)\", color=DIM, fontsize=8)\n",
    "ax1.invert_yaxis()\n",
    "\n",
    "# ── 2. Route comparison — CO₂ ─────────────────────────────────────\n",
    "ax2 = fig.add_subplot(gs[0, 1])\n",
    "style_ax(ax2, \"CO₂ Emissions by Strategy (t)\")\n",
    "co2s = [r.total_co2_kg/1000 for r in alts]\n",
    "bars2 = ax2.barh(labels, co2s, color=[AMBER if r.is_eco else ORANGE for r in alts],\n",
    "                 alpha=0.8, height=0.55, edgecolor=\"#0d2545\")\n",
    "for bar, v in zip(bars2, co2s):\n",
    "    ax2.text(v + 0.5, bar.get_y() + bar.get_height()/2,\n",
    "             f\"{v:.1f}t\", va=\"center\", color=\"#c8dff0\", fontsize=8)\n",
    "ax2.set_xlabel(\"CO₂ (tonnes)\", color=DIM, fontsize=8)\n",
    "ax2.invert_yaxis()\n",
    "\n",
    "# ── 3. Emission phase breakdown — donut ───────────────────────────\n",
    "ax3 = fig.add_subplot(gs[0, 2])\n",
    "style_ax(ax3, \"CO₂ Phase Breakdown\")\n",
    "phases = list(analysis.emission_breakdown.keys())\n",
    "vals   = list(analysis.emission_breakdown.values())\n",
    "pcols  = [CYAN, AMBER, ORANGE, \"#a78bfa\"]\n",
    "wedges, texts, autotexts = ax3.pie(\n",
    "    vals, labels=phases, autopct=\"%1.1f%%\",\n",
    "    colors=pcols, startangle=90,\n",
    "    wedgeprops=dict(width=0.55, edgecolor=DARK),\n",
    "    textprops=dict(color=\"#c8dff0\", fontsize=7.5)\n",
    ")\n",
    "for at in autotexts: at.set_color(DARK); at.set_fontsize(7)\n",
    "ax3.text(0, 0, f\"{analysis.eco_route.total_co2_kg/1000:.1f}\\nt CO₂\",\n",
    "         ha=\"center\", va=\"center\", color=AMBER, fontsize=9, fontweight=\"bold\")\n",
    "\n",
    "# ── 4. Wind profile ───────────────────────────────────────────────\n",
    "ax4 = fig.add_subplot(gs[1, :])\n",
    "style_ax(ax4, \"Wind Component Along Route (kt)  —  Tailwind (+) / Headwind (−)\")\n",
    "wp_arr = np.array(analysis.wind_profile)\n",
    "x = np.linspace(0, 100, len(wp_arr))\n",
    "\n",
    "ax4.axhline(0, color=DIM, linewidth=0.8, linestyle=\"--\")\n",
    "ax4.fill_between(x, wp_arr, 0,\n",
    "                  where=(wp_arr >= 0), interpolate=True,\n",
    "                  color=GREEN, alpha=0.25, label=\"Tailwind\")\n",
    "ax4.fill_between(x, wp_arr, 0,\n",
    "                  where=(wp_arr < 0), interpolate=True,\n",
    "                  color=ORANGE, alpha=0.25, label=\"Headwind\")\n",
    "ax4.plot(x, wp_arr, color=GREEN, linewidth=2,\n",
    "         path_effects=[\n",
    "             __import__('matplotlib.patheffects', fromlist=['withStroke'])\n",
    "             .withStroke(linewidth=4, foreground='#001a33', alpha=0.7)\n",
    "         ])\n",
    "ax4.scatter(x, wp_arr, color=CYAN, s=20, zorder=5, alpha=0.7)\n",
    "ax4.set_xlabel(\"Route Progress (%)\", color=DIM, fontsize=8)\n",
    "ax4.set_ylabel(\"Wind (kt)\",          color=DIM, fontsize=8)\n",
    "ax4.set_xlim(0, 100)\n",
    "ax4.legend(facecolor=PANEL, edgecolor=\"#0d2545\", labelcolor=\"#c8dff0\", fontsize=8)\n",
    "\n",
    "# ── Super-title ───────────────────────────────────────────────────\n",
    "fig.suptitle(\n",
    "    f\"AeroNav AI  ·  {origin.code} → {dest.code}  ·  {aircraft.name}  ·  {PRIORITY.upper()}\",\n",
    "    color=\"#00d4ff\", fontsize=13, fontweight=\"bold\", y=0.98\n",
    ")\n",
    "\n",
    "plt.savefig(\"eco_dashboard.png\", dpi=150, bbox_inches=\"tight\", facecolor=DARK)\n",
    "plt.show()\n",
    "print(\"✅ Dashboard saved → eco_dashboard.png\")"
   ]
  },
