    "import google.generativeai as genai\n",
    "import os\n",
    "\n",
    "# ── Gemini AI insight ─────────────────────────────────────────────────────────\n",
    "def fetch_ai_insight(analysis) -> str:\n",
    "    \"\"\"Call Gemini for a technical pilot briefing on the eco route.\"\"\"\n",
    "    api_key = os.environ.get(\"GEMINI_API_KEY\", \"\").strip()\n",
    "    if not api_key or api_key == \"AIzaSyCimRcV3ohh3gOHc0EY8dOMpDhMlDP9daI\":\n",
    "        return (f\"Eco route computed for {analysis.origin.code}–{analysis.destination.code}. \"\n",
    "                f\"FL{analysis.cruise_fl} cruise with jet-stream alignment yields \"\n",
    "                f\"{analysis.fuel_saved_kg:,} kg fuel reduction. [No Gemini API key set]\")\n",
    "\n",
    "    prompt = (\n",
    "        \"You are AeroNav AI, an expert aviation fuel efficiency system.\\n\"\n",
    "        \"Give a concise technical pilot briefing (2-3 sentences) for this flight:\\n\\n\"\n",
    "        f\"Route: {analysis.origin.code} → {analysis.destination.code}\\n\"\n",
    "        f\"Aircraft: {analysis.aircraft.name}  |  Priority: {analysis.priority}\\n\"\n",
    "        f\"Cruise FL{analysis.cruise_fl}  |  Distance: {analysis.distance_nm:,.0f} NM\\n\"\n",
    "        f\"Fuel saved vs standard: {analysis.fuel_saved_kg:,} kg\\n\"\n",
    "        f\"CO2 avoided: {analysis.co2_saved_kg:,} kg\\n\"\n",
    "        f\"Time delta: {'+' if analysis.time_delta_min >= 0 else ''}{analysis.time_delta_min} min\\n\\n\"\n",
    "        \"Mention jet streams, altitude optimization, or contrail avoidance as relevant.\\n\"\n",
    "        \"Be direct and technical. No bullet points.\"\n",
    "    )\n",
    "\n",
    "    try:\n",
    "        genai.configure(api_key=api_key)\n",
    "        # Use gemini-1.5-flash (widely available free-tier model)\n",
    "        model = genai.GenerativeModel(\"gemini-1.5-flash\")\n",
    "        response = model.generate_content(prompt)\n",
    "        return response.text.strip()\n",
    "    except Exception as e:\n",
    "        return (f\"Eco route computed for {analysis.origin.code}–{analysis.destination.code}. \"\n",
    "                f\"FL{analysis.cruise_fl} cruise with jet-stream alignment yields \"\n",
    "                f\"{analysis.fuel_saved_kg:,} kg fuel reduction. [Gemini API error: {e}]\")\n",
    "\n",
    "\n",
    "# ── MongoDB Atlas storage ─────────────────────────────────────────────────────\n",
    "\n",
    "def save_to_mongodb(analysis, insight: str) -> bool:\n",
    "    \"\"\"\n",
    "    Persist a flight analysis record to MongoDB Atlas.\n",
    "    Collection: aeronav_db.flight_analyses\n",
    "    Returns True on success, False on failure.\n",
    "    \"\"\"\n",
    "    uri = os.environ.get(\"MONGODB_URI\", \"\").strip()\n",
    "    if not uri or uri == \"mongodb+srv://...\":\n",
    "        print(\"ℹ️  MongoDB URI not set — skipping Atlas save.\")\n",
    "        print(\"   Set os.environ['MONGODB_URI'] = 'mongodb+srv://<user>:<pass>@...'\")\n",
    "        return False\n",
    "    try:\n",
    "        from pymongo import MongoClient\n",
    "        from datetime import datetime, timezone\n",
    "        client = MongoClient(uri, serverSelectionTimeoutMS=5000)\n",
    "        db  = client[\"aeronav_db\"]\n",
    "        col = db[\"flight_analyses\"]\n",
    "\n",
    "        doc = {\n",
    "            \"saved_at\": datetime.now(timezone.utc),\n",
    "            \"flight\": {\n",
    "                \"origin\":      {\"code\": analysis.origin.code,      \"name\": analysis.origin.name,\n",
    "                                \"lat\":  analysis.origin.lat,       \"lon\":  analysis.origin.lon},\n",
    "                \"destination\": {\"code\": analysis.destination.code, \"name\": analysis.destination.name,\n",
    "                                \"lat\":  analysis.destination.lat,  \"lon\":  analysis.destination.lon},\n",
    "                \"aircraft\":    {\"code\": analysis.aircraft.code,    \"name\": analysis.aircraft.name,\n",
    "                                \"burn_rate_kg_per_hr\": analysis.aircraft.burn_rate_kg_per_hr},\n",
    "                \"priority\":    analysis.priority,\n",
    "                \"cruise_fl\":   analysis.cruise_fl,\n",
    "                \"distance_nm\": analysis.distance_nm,\n",
    "            },\n",
    "            \"eco_metrics\": {\n",
    "                \"fuel_saved_kg\":  analysis.fuel_saved_kg,\n",
    "                \"co2_saved_kg\":   analysis.co2_saved_kg,\n",
    "                \"time_delta_min\": analysis.time_delta_min,\n",
    "            },\n",
    "            \"eco_route\": {\n",
    "                \"total_fuel_kg\":   analysis.eco_route.total_fuel_kg,\n",
    "                \"total_co2_kg\":    analysis.eco_route.total_co2_kg,\n",
    "                \"flight_time_min\": analysis.eco_route.flight_time_min,\n",
    "                \"waypoints\": [\n",
    "                    {\"name\": w.name, \"lat\": w.lat, \"lon\": w.lon,\n",
    "                     \"altitude_fl\": w.altitude_fl, \"wind_kt\": w.wind_kt}\n",
    "                    for w in analysis.waypoints\n",
    "                ],\n",
    "            },\n",
    "            \"emission_breakdown\": analysis.emission_breakdown,\n",
    "            \"wind_profile_kt\":    analysis.wind_profile,\n",
    "            \"ai_insight\":         insight,\n",
    "        }\n",
    "\n",
    "        result = col.insert_one(doc)\n",
    "        print(f\"✅ Saved to MongoDB Atlas  |  _id: {result.inserted_id}\")\n",
    "        client.close()\n",
    "        return True\n",
    "\n",
    "    except Exception as e:\n",
    "        print(f\"⚠️  MongoDB save failed: {e}\")\n",
    "        return False\n",
    "\n",
    "\n",
    "print(\"✅ Gemini AI + MongoDB Atlas module ready\")\n"
   ]
  },
